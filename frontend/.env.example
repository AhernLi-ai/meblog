# Next.js Environment Variables
# These variables are exposed to the browser and must be prefixed with NEXT_PUBLIC_
# Loading rule (custom):
# - NEXT_PUBLIC_ENV=test        -> load .env.test
# - NEXT_PUBLIC_ENV=production  -> load .env.production
# - otherwise                   -> load .env.local

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_ENV=development

# Production Example (for .env.production)
# NEXT_PUBLIC_API_BASE_URL=https://yourdomain.com/api/v1
# NEXT_PUBLIC_ENV=production

# Test Example (for .env.test)
# NEXT_PUBLIC_API_BASE_URL=http://116.62.176.216:8000/api/v1
# NEXT_PUBLIC_ENV=test