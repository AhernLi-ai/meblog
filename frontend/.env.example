# Next.js Environment Variables
# These variables are exposed to the browser and must be prefixed with NEXT_PUBLIC_
# Loading rule (custom):
# - NEXT_PUBLIC_ENV=test        -> load .env.test
# - NEXT_PUBLIC_ENV=production  -> load .env.production
# - otherwise                   -> load .env.local

NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1
SERVER_API_BASE_URL=http://127.0.0.1:8000/api/v1
NEXT_PUBLIC_API_ORIGIN=http://127.0.0.1:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000
NEXT_PUBLIC_ENV=local
REVALIDATE_SECRET=change-me
# Optional: fallback base for cover images (Scheme A, e.g. Gitee raw base)
# Example: https://gitee.com/<user>/<repo>/raw/main/covers
NEXT_PUBLIC_GITEE_ASSETS_BASE=

# Production Example (for .env.production)
# NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api/v1
# NEXT_PUBLIC_API_ORIGIN=https://api.yourdomain.com
# NEXT_PUBLIC_ENV=production

# Test Example (for .env.test)
# NEXT_PUBLIC_API_BASE_URL=http://116.62.176.216:8000/api/v1
# NEXT_PUBLIC_ENV=test