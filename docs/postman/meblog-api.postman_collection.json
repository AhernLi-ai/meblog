            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"my post\",\n  \"content\": \"markdown content\",\n  \"summary\": \"summary\",\n  \"project_id\": null,\n  \"tag_ids\": [],\n  \"status\": \"published\"\n}"
