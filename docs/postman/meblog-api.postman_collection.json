      "item": [
        {
          "name": "List Posts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/posts?page=1&size=10&project=&tag=&q=",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "posts"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "project",
                  "value": ""
                },
                {
                  "key": "tag",
                  "value": ""
                },
                {
                  "key": "q",
                  "value": ""
