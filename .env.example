# Frontend Environment Variables (Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_ENV=development

# Backend Environment Variables (FastAPI)
DATABASE_URL=postgresql://username:password@localhost:5432/database_name
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1
DEBUG=true

# Production Example (for .env.production)
# NEXT_PUBLIC_API_BASE_URL=https://yourdomain.com/api/v1
# NEXT_PUBLIC_ENV=production
# DATABASE_URL=postgresql://memblog:memblog@common-postgres:5432/memblog
# REDIS_URL=redis://common-redis:6379/0
# SECRET_KEY=your-production-secret-key
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# DEBUG=false

# Test Example (for .env.test)  
# DATABASE_URL=postgresql://admin:admin@common-postgres:5432/memblog_test
# REDIS_URL=redis://common-redis:6379/0
# SECRET_KEY=test-secret-key-2026
# ALLOWED_HOSTS=localhost,127.0.0.1,116.62.176.216
# DEBUG=true