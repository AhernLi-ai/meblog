# =====================================
# Database Configuration
# =====================================
# Local Development
DATABASE_URL=sqlite:///./meblog.db
TEST_DATABASE_URL=sqlite:///:memory:

# Remote PostgreSQL Example (customize host/port yourself)
# DATABASE_URL=postgresql://test:test@<db-host>:<db-port>/meblog_test

# Test Environment (Docker)
# DATABASE_URL=postgresql://test:test@common-postgres:5432/meblog_test

# Production Environment (Docker)  
# DATABASE_URL=postgresql://memblog:memblog@common-postgres:5432/memblog

# =====================================
# Redis Configuration
# =====================================
# Local Development
REDIS_URL=redis://localhost:6379/0

# Test/Production Environment (Docker)
# REDIS_URL=redis://common-redis:6379/0

# =====================================
# Security & Application Settings
# =====================================
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
DEBUG=true
APP_ENV=local

# =====================================
# Usage Instructions
# =====================================
# 1. Create env files as needed: .env.local / .env.test / .env.production
# 2. Fill DATABASE_URL / REDIS_URL with your actual values
# 3. Set SECRET_KEY to a strong random value in production
# 4. Set APP_ENV to local/test/production