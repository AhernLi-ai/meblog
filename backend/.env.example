# =====================================
# Database Configuration
# =====================================
# Local Development
DATABASE_URL=postgresql://admin:admin@localhost:6001/memblog_test

# Test Environment (Docker)
# DATABASE_URL=postgresql://admin:admin@common-postgres:5432/memblog_test

# Production Environment (Docker)  
# DATABASE_URL=postgresql://memblog:memblog@common-postgres:5432/memblog

# =====================================
# Redis Configuration
# =====================================
# Local Development
REDIS_URL=redis://localhost:6379/0

# Test/Production Environment (Docker)
# REDIS_URL=redis://common-redis:6379/0

# =====================================
# Security & Application Settings
# =====================================
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,116.62.176.216
DEBUG=true
ENV=development

# =====================================
# Usage Instructions
# =====================================
# 1. Copy this file to .env.local for local development
# 2. Copy this file to .env.test for test environment  
# 3. Copy this file to .env.production for production environment
# 4. Uncomment and modify the appropriate DATABASE_URL and REDIS_URL lines
# 5. Set SECRET_KEY to a strong random value in production
# 6. Set DEBUG=false and ENV=production in production environment